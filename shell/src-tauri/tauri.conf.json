{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AnimeWatcherPlus",
  "version": "0.1.0",
  "identifier": "com.animewatcherplus.app",
  "build": {
    "frontendDist": "../ui/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm --prefix ../ui run dev",
    "beforeBuildCommand": "npm --prefix ../ui run build"
  },
  "app": {
    "windows": [
      {
        "title": "AnimeWatcherPlus",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "createUpdaterArtifacts": true,
    "externalBin": ["binaries/core"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDc0QTZFNjUwQzdDNDRBMEEKUldRS1NzVEhVT2FtZE52SjE5UWhycjRvRU14SWxTcGhVdThqTFRMbkNFSG5ZTFdKeEU2aTdrcTgK",
      "endpoints": [
        "https://github.com/LinkDarkshire/AnimeWatcherPlus/releases/latest/download/latest.json"
      ]
    }
  }
}
